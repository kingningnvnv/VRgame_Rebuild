  m_Script: {fileID: 11500000, guid: 5f7201a12d95ffc409449d95f23cf332, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 0.19607843, g: 0.19607843, b: 0.19607843, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_FontData:
    m_Font: {fileID: 12800000, guid: 997a43b767814dd0a7642ec9b78cba41, type: 3}
    m_FontSize: 28
    m_FontStyle: 0
    m_BestFit: 0
    m_MinSize: 2
    m_MaxSize: 40
    m_Alignment: 0
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: '1. Shake the seasoning shaker and season the steak with salt and pepper

    2.
    Place the frying pan on the hob and turn the knob clockwise to light the flame

    3.
    Use an oil sprayer to coat the frying pan with a thin layer of oil

    4. Place
    the steak in the pan, then add garlic, rosemary and butter

    5. Flip the steak
    and cook until done

    6. Plate up and serve to the designated area, then settle
    the bill.



    Other operations:

    Hold the tongs near the steak and press
    the X button to pick it up

    Hold the oil sprayer, aim it at the frying pan
    and press the B button to spray a layer of oil

    Steaks can also be cooked
    in the Griller area'
