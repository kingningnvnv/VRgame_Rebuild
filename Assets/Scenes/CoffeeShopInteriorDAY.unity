    m_Font: {fileID: 12800000, guid: 997a43b767814dd0a7642ec9b78cba41, type: 3}
    m_FontSize: 28
    m_FontStyle: 0
    m_BestFit: 0
    m_MinSize: 2
    m_MaxSize: 40
    m_Alignment: 1
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: "How to Cook the Steak\n\n1. Pick up a raw steak with clip by pressing
    X.\nMarinate the steak with salt and  pepper.\n2.Switch the button below to turn
    on the stove \n3.Aim the sprayer at the pan and press B to spray oil.\nPlace
    steak on the heated pan or grill.\n4. Flip it to cook both sides and see the
    doneness change.Don't forget to put butter,gralic and thyme into the  pan to
    add some flavor to steak.\n5. Remove it before it burns.\n6. Put it on the plate.\n7.
    Submit the dish for scoring."
